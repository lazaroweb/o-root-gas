# Config do Firebase — copie este arquivo pra `.env` e preencha com os valores
# do seu projeto (Console Firebase > Configurações do projeto > Seus apps > Web).
# Esses valores identificam o projeto (não são segredos), mas ficam fora do git
# por higiene. A segurança real são as security rules do Firestore.
VITE_FIREBASE_API_KEY=
# IMPORTANTE: use o domínio do Hosting (<project-id>.web.app), NÃO o
# firebaseapp.com — senão o popup de login vira cross-origin e o Chrome
# bloqueia a sessão (loop de login sem erro).
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
# App Check (opcional, proteção de custo): site key do reCAPTCHA v3 criada em
# Console Firebase > App Check > registrar app web. Vazio = App Check desligado.
VITE_APPCHECK_SITE_KEY=
